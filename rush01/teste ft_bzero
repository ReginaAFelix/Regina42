#include <unistd.h>

void	ft_bzero(void *s, size_t n)
{
	unsigned char	*ptr;
	size_t			i;

	ptr = (unsigned char *)s;
	i = 0;
	while (i < n)
	{
		ptr[i] = 0;
		i++;
	}
}

int	main(int argc, char **argv)
{
	int	grid[4][4];

	(void)argc;
	(void)argv;
	ft_bzero(grid, sizeof(grid));
	return (0);
}

